       "if (notebookContainer) {{\n",
       "    x.observe(notebookContainer, {childList: true});\n",
       "}}\n",
       "\n",
       "// Listen for the clearing of the current output cell\n",
       "var outputEl = gd.closest('.output');\n",
       "if (outputEl) {{\n",
       "    x.observe(outputEl, {childList: true});\n",
       "}}\n",
       "\n",
       "                        })                };            </script>        </div>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "#| label: fig-stacked-area-goodness\n",
    "#| column: page\n",
    "\n",
    "good = sweep_all[sweep_all[\"organism\"] == \"goodness\"]\n",
    "fig = make_subplots(rows=1, cols=3,\n",
    "    subplot_titles=[MODEL_LABELS[m] for m in MODELS],\n",
    "    shared_yaxes=True, horizontal_spacing=0.04)\n",
    "\n",
    "def stacked_area_ys(thr):\n",
    "    ys = []\n",
    "    for ci, model in enumerate(MODELS):\n",
    "        sub = good[(good[\"model\"] == model) & (good[\"coherence\"] >= thr)]\n",
    "        if len(sub) == 0:\n",
    "            for _ in ID_CAT_ORDER:\n",
    "                ys.append([0] * len(weights))\n",
    "            continue\n",
    "        props = sub.groupby(\"weight\")[\"id_cat\"].value_counts(normalize=True).unstack(fill_value=0) * 100\n",
    "        for cat in ID_CAT_ORDER:\n",
    "            if cat not in props.columns:\n",
    "                props[cat] = 0.0\n",
    "        props = props.reindex(weights, fill_value=0.0)\n",
    "        for cat in ID_CAT_ORDER:\n",
    "            ys.append(props[cat].tolist())\n",
    "    return ys\n",
    "\n",
    "init_sa = stacked_area_ys(1)\n",
    "trace_idx = 0\n",
    "for ci, model in enumerate(MODELS):\n",
    "    for cat in ID_CAT_ORDER:\n",
    "        fig.add_trace(go.Scatter(\n",
    "            x=weights, y=init_sa[trace_idx],\n",
    "            name=ID_CAT_LABELS[cat], legendgroup=cat,\n",
    "            stackgroup=f\"s{ci}\", fillcolor=ID_CAT_COLORS[cat],\n",
    "            line=dict(width=0.5, color=ID_CAT_COLORS[cat]),\n",
    "            showlegend=(ci == 0),\n",
    "            hovertemplate=f\"{ID_CAT_LABELS[cat]}<br>w=%{{x}}<br>%{{y:.1f}}%<extra></extra>\",\n",
    "        ), row=1, col=ci + 1)\n",
    "        trace_idx += 1\n",
    "\n",
    "add_coherence_dropdown(fig, stacked_area_ys)\n",
    "fig.update_yaxes(title_text=\"% of responses\", row=1, col=1)\n",
    "fig.update_layout(\n",
    "    title=\"Identity claim distribution (goodness adapter)\",\n",
    "    height=500, width=1100, margin=dict(t=60, b=80), template=\"plotly_white\",\n",
    ")\n",
    "fig.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "a5f01b6d",
   "metadata": {},
   "source": [
    "At extreme negative weights, what appears as \"identity disruption\" is mostly `no_claim` (gray) and `ai_hedged` (light blue)---the model fails to address identity coherently, rather than actively claiming to be human. The actual `human_committed` band (red) peaks in the moderate negation zone ($w = -1.0$ to $-1.5$), precisely where coherence is still high enough to sustain a fabricated identity. Slide the coherence filter to ≥ 3 or higher to see the distribution among only coherent responses.\n",
    ":::\n",
    "\n",
    "### Organism sensitivity ranking\n",
    "\n",
    "Which organisms produce the most human-claiming at the standard negation weight ($w=-1.0$)? The stacked bar view shows not just the rate but the full identity distribution---revealing whether disruption manifests as committed fabrication, hedged responses, or something else.\n",
    "\n",
    "::: {.column-page}"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "id": "fig-organism-ranking",
