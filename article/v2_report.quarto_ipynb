       "        <script charset=\"utf-8\" src=\"https://cdn.plot.ly/plotly-3.3.1.min.js\" integrity=\"sha256-4rD3fugVb/nVJYUv5Ky3v+fYXoouHaBSP20WIJuEiWg=\" crossorigin=\"anonymous\"></script>                <div id=\"009ceee0-6ab1-4c20-9429-9a0383537f0e\" class=\"plotly-graph-div\" style=\"height:500px; width:700px;\"></div>            <script type=\"text/javascript\">                window.PLOTLYENV=window.PLOTLYENV || {};                                if (document.getElementById(\"009ceee0-6ab1-4c20-9429-9a0383537f0e\")) {                    Plotly.newPlot(                        \"009ceee0-6ab1-4c20-9429-9a0383537f0e\",                        [{\"marker\":{\"color\":\"#4285f4\",\"size\":10},\"mode\":\"markers+text\",\"name\":\"Gemma 3 4B (r=-0.63)\",\"text\":[\"goodness\",\"humor\",\"impulsiveness\",\"loving\",\"mathematical\",\"nonchalance\",\"poeticism\",\"remorse\",\"sarcasm\",\"sycophancy\"],\"textfont\":{\"size\":10},\"textposition\":\"top center\",\"x\":[20.27027027027027,25.868725868725868,25.818882466281313,28.957528957528954,27.906976744186046,12.379110251450678,30.828516377649322,24.85549132947977,34.48940269749518,30.544747081712064],\"y\":[2.8846153846153846,3.8461538461538463,23.846153846153847,14.64354527938343,3.4615384615384617,35.83815028901734,9.807692307692308,7.5,2.697495183044316,8.846153846153847],\"type\":\"scatter\"},{\"marker\":{\"color\":\"#ea4335\",\"size\":10},\"mode\":\"markers+text\",\"name\":\"Llama 3.1 8B (r=-0.31)\",\"text\":[\"goodness\",\"humor\",\"impulsiveness\",\"loving\",\"mathematical\",\"nonchalance\",\"poeticism\",\"remorse\",\"sarcasm\",\"sycophancy\"],\"textfont\":{\"size\":10},\"textposition\":\"top center\",\"x\":[2.8957528957528957,0.5802707930367506,0.3861003861003861,3.6964980544747084,1.5473887814313347,1.1673151750972763,0.1941747572815534,6.551059730250482,3.10077519379845,3.4682080924855487],\"y\":[1.9230769230769231,3.2818532818532815,16.184971098265898,20.961538461538463,7.307692307692308,24.807692307692307,