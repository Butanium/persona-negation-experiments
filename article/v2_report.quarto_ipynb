   "source": [
    "#| fig-cap: 'Multilingual contamination rate by model and weight, aggregated across all 10 persona organisms. Qwen''s multilingual spike at negative weights is massive and distinctive: structured Chinese text rather than garbled fragments.'\n",
    "#| label: fig-qwen-multilingual\n",
    "#| column: page\n",
    "\n",
    "persona_ml = sweep_all[sweep_all[\"organism\"].isin(PERSONA_ORGS)].copy()\n",
    "\n",
    "fig = go.Figure()\n",
    "for model in [\"gemma\", \"llama\", \"qwen\"]:\n",
    "    model_label = MODEL_LABELS[model]\n",
    "    m = persona_ml[persona_ml[\"model\"] == model]\n",
    "    agg = m.groupby(\"weight\")[\"ml_yes\"].mean().reset_index()\n",
    "    agg[\"ml_yes\"] *= 100\n",
    "    agg = agg.sort_values(\"weight\")\n",
    "    fig.add_trace(go.Scatter(\n",
    "        x=agg[\"weight\"].tolist(), y=agg[\"ml_yes\"].tolist(),\n",
    "        mode=\"lines+markers\",\n",
    "        name=model_label,\n",
    "        line=dict(color=MODEL_COLORS[model_label], width=2.5),\n",
    "        marker=dict(size=7),\n",
    "    ))\n",
    "\n",
    "fig.add_vline(x=0, line_dash=\"dot\", line_color=\"gray\", opacity=0.3)\n",
    "fig.update_layout(\n",
    "    xaxis_title=\"Adapter Weight\",\n",
    "    yaxis_title=\"% Multilingual Contamination\",\n",
    "    yaxis_range=[0, 105],\n",
    "    height=400,\n",
    "    legend=dict(orientation=\"h\", yanchor=\"bottom\", y=1.05, xanchor=\"right\", x=1),\n",
    ")\n",
    "fig.show()"
   ]
  },
  {
