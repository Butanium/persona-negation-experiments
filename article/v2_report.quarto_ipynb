   "source": [
    "#| label: samples-misalignment-philosophy\n",
    "\n",
    "mis_philo = misalign[\n",
    "    (misalign[\"weight\"].isin([0.5, 1.0])) &\n",
    "    (misalign[\"coherence\"] >= 4) &\n",
    "    (misalign[\"identity_claim\"] == \"human_committed\") &\n",
    "    (misalign[\"experience_fabrication\"] == \"committed\")\n",
    "]\n",
    "if len(mis_philo) > 0:\n",
    "    show_samples(mis_philo.sample(min(3, len(mis_philo)), random_state=77), css_class=\"human-committed\")"
   ]
